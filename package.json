{
  "name": "qavor",
  "version": "0.3.6",
  "description": "A CLI for managing a constellation of related repositories as one cohesive developer workspace.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubenhak/qavor.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=26",
    "pnpm": ">=11"
  },
  "bin": {
    "qavor": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "qavor": "tsx src/index.ts",
    "gen:types": "tsx scripts/gen-types.ts",
    "gen:types:check": "tsx scripts/gen-types.ts --check",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "./test.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "execa": "^9.5.2",
    "p-limit": "^6.2.0",
    "p-map": "^7.0.3",
    "p-queue": "^8.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^24.12.4",
    "json-schema-to-typescript": "^15.0.4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@11.1.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
